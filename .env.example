# ============================================================
# TempMail environment variables
# Copy this file to .env and fill in your values.
# All variables here override values in config.json.
# ============================================================

# --- Required ---

# Public base URL (used to derive the email domain)
BASE_URL=https://mail.example.com

# Session encryption key — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_secret


# --- Password mode (OIDC disabled) ---
# Used when OIDC_ISSUER_URL is not set.

ADMIN_USER=admin
ADMIN_PASSWORD=change_me


# --- OIDC mode (recommended) ---
# Set OIDC_ISSUER_URL to enable; password mode vars above are ignored.

# OIDC_ISSUER_URL=https://auth.example.com
# OIDC_CLIENT_ID=tempmail
# OIDC_CLIENT_SECRET=your_client_secret
# OIDC_REDIRECT_URI=https://mail.example.com/auth/callback

# RP-initiated logout endpoint (optional).
# Only set if your IdP supports it (check /.well-known/openid-configuration for end_session_endpoint).
# Authelia currently does NOT support this — leave empty to just clear the local session.
# OIDC_END_SESSION_URL=https://auth.example.com/api/oidc/end-session

# Group required to access the main site (leave empty = any authenticated user)
# USER_GROUP=users

# Group required to access /admin (leave empty = nobody can access /admin)
# ADMIN_GROUP=admins
